{
  "name": "setup-firebase",
  "version": "1.0.0",
  "description": "Setup Firebase Action",
  "main": "dist/action.js",
  "scripts": {
    "build": "npm run build:main && npm run build:cleanup",
    "build:main": "esbuild src/setup-firebase.ts --bundle --platform=node --target=node24 --format=cjs --minify --outfile=dist/action.js",
    "build:cleanup": "esbuild src/cleanup.ts --bundle --platform=node --target=node24 --format=cjs --minify --outfile=dist/cleanup.js",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format-check": "prettier --check ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/e11community/setup-firebase.git"
  },
  "keywords": [
    "actions",
    "firebase",
    "setup"
  ],
  "author": "Engineering 11",
  "license": "MIT",
  "devDependencies": {
    "@types/command-exists": "^1.2.3",
    "@types/node": "^24.12.4",
    "esbuild": "^0.28.0",
    "gts": "^5.3.1",
    "prettier": "^3.6.0",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "@actions/cache": "^3.2.4",
    "@actions/core": "^1.10.1",
    "@actions/exec": "^1.1.1",
    "@actions/io": "^1.1.3",
    "command-exists": "^1.2.9"
  }
}
